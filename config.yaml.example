broker:
  use_sandbox: true
  currency: "rub"
  min_sandbox_cash_rub: 12000
  log_file: "logs/bot.log"
  key_log_file: "logs/key_events.log"
  class_code: "TQBR"
  buy_aggressive_ticks: 1
  sell_aggressive_ticks: 1
  trades_csv: "logs/trades.csv"

  retry_tries: 3
  retry_sleep_min: 1.0
  retry_sleep_max: 10.0

  sandbox_pay_in_rub: 100000.0

universe:
  tickers: ["SBER", "GAZP", "LKOH", "GMKN", "TATN", "NVTK", "ROSN", "ALRS"]

schedule:
  tz: "Europe/Moscow"
  start_trade: "10:20"
  stop_new_entries: "18:05"
  flatten_time: "18:40"

strategy:
  lookback_minutes: 180
  k_atr: 1.35
  take_profit_pct: 0.0055
  stop_loss_pct: 0.0055
  time_stop_minutes: 35

  min_edge_atr: 0.08
  max_rebound_atr: 0.20

  time_stop_tighten_stop_loss_pct: 0.0025
  breakeven_pct: 0.0005
  enable_time_stop_safe_exit: true

risk:
  max_lot_cost_rub: 3500
  max_day_loss_rub: 1000
  max_trades_per_day: 20

  max_positions: 5
  max_active_orders_per_figi: 1
  max_pending_buys_total: 5
  max_active_orders_total: 5

runtime:
  sleep_sec: 55
  heartbeat_sec: 300
  portfolio_sec: 1800
  error_sleep_sec: 10
  max_consecutive_errors: 8
  reports_dir: "logs/reports"
  order_ttl_sec: 90

telegram:
  enabled: true
  compact_mode: true
  send_startup: true
  send_signals: false
  send_orders: true
  send_fills: true
  send_pnl: true
  send_portfolio_snapshots: false
  send_daily_report: true
  send_warnings: true
  send_errors: true
  send_service: true
  send_rejects: true
  send_cancels: false
  send_expires: false
